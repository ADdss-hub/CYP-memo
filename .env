# 应用基本配置
APP_NAME=CYP备忘录
APP_VERSION=v0.1.2
APP_ENV=production
DEBUG=false

# 数据库配置
DATABASE_URL=sqlite:///./cyp_memo.db

# Redis配置
REDIS_URL=redis://redis:6379/0

# 认证配置
SECRET_KEY=your-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# WebDAV配置
WEBDAV_ENABLED=true
WEBDAV_PORT=5000
WEBDAV_URL=/webdav

# 文件存储配置
UPLOAD_DIR=uploads
DATA_DIR=data
MAX_FILE_SIZE=52428800
